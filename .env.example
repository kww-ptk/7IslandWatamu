# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=7island
DB_USER=your_db_user
DB_PASS=your_db_password

# Mail
# Preferred: Resend (https://resend.com). If RESEND_API_KEY is set, all email
# is sent via the Resend API and MAIL_DRIVER/SMTP_* below are ignored.
# MAIL_FROM must be on a domain you have verified in the Resend dashboard.
RESEND_API_KEY=
MAIL_FROM=noreply@yourdomain.com

# Fallback only (used when RESEND_API_KEY is empty): "mail" = PHP mail(), "smtp" = not implemented
MAIL_DRIVER=mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Site — canonical public URL. Drives email links, the sitemap (sitemap.php),
# and site_url() helpers. Set this to your real domain in production; if unset,
# the code falls back to the request host.
SITE_URL=https://yourdomain.com

# hCaptcha (anti-spam — get free keys at dashboard.hcaptcha.com)
# Sign up, add a site, copy the Site Key and Secret Key here.
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Hold/booking token signing (required for one-click Confirm/Decline buttons in admin emails)
# Generate with: openssl rand -hex 32
BOOKING_TOKEN_SECRET=

# iCal sync (optional — protects /api/sync-ical.php endpoint)
# Generate with: openssl rand -hex 20
ICAL_SYNC_SECRET=

# Cloudflare R2 image storage (optional — falls back to local disk if not set)
# R2_ACCOUNT_ID=your_account_id
# R2_BUCKET=7island-images
# R2_ACCESS_KEY=your_r2_access_key_id
# R2_SECRET_KEY=your_r2_secret_access_key
# R2_PUBLIC_URL=https://pub-XXXX.r2.dev
